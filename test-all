#!/usr/bin/env bash
# Run the complete local 1x1 RTL verification set.
set -euo pipefail

here="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$here"

if ! command -v iverilog >/dev/null 2>&1 || ! command -v make >/dev/null 2>&1; then
  echo "Test tools are missing. Run ./setup-live once, then retry ./test-all." >&2
  exit 1
fi

if [ -x "$here/.venv/bin/python" ]; then
  py="$here/.venv/bin/python"
elif [ -x "$HOME/.venvs/ja-achtung/bin/python" ]; then
  py="$HOME/.venvs/ja-achtung/bin/python"
elif [ -n "${VIRTUAL_ENV:-}" ] && [ -x "$VIRTUAL_ENV/bin/python" ]; then
  py="$VIRTUAL_ENV/bin/python"
else
  py="$(command -v python3 || command -v python || true)"
fi

if [ -z "${py:-}" ] || ! "$py" -c "import cocotb" 2>/dev/null; then
  echo "The test environment is not ready. Run ./setup-live once." >&2
  exit 1
fi

# The cocotb Makefile locates cocotb-config through PATH.
export PATH="$(dirname "$py"):$PATH"

echo "[1/6] Full-size game, VGA, QSPI PSRAM, input, and arbitration tests"
"$py" "Game Simulation/tests/game_1x1/run.py" --test all --rebuild

echo "[2/6] Accelerated coarse game-logic trace suite"
"$py" "Game Simulation/tests/game_1x1/run.py" --test suite --mode coarse --rebuild

echo "[3/6] Standalone PSRAM controller and display-streamer tests"
"$py" "Game Simulation/tests/ram/run.py" --target 1x1-minimal --rebuild

echo "[4/6] Tiny Tapeout top-level pin test"
(
  cd test
  make clean
  make
)

echo "[5/6] Exhaustive compact gamepad decoder test"
iverilog -g2012 -DCOCOTB_SIM -I src \
  -s tb_decoder_exhaustive \
  -o test/decoder_exhaustive.vvp \
  test/tb_decoder_exhaustive.sv \
  src/tt_um_ja_achtung_1x1.v src/psram_controller.v \
  src/display_streamer.v src/game_fsm.v src/vga_sync.v
vvp test/decoder_exhaustive.vvp | tee test/decoder_exhaustive.log
grep -q "PASS compact decoder exhaustive: cases=8193 failures=0" \
  test/decoder_exhaustive.log

echo "[6/6] Hardening-metric policy unit tests"
"$py" tools/test_check_harden_metrics.py -q

echo "All 1x1 local tests passed."
